{
  "name": "stroke-predict-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --strictPort",
    "build": "tsc --noEmit -p tsconfig.json && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:compile": "tsc -p tsconfig.node.json && node scripts/build-preload-cjs.cjs",
    "electron:dev": "concurrently \"npm:dev\" \"wait-on http://127.0.0.1:5173 && npm run electron:compile && electron .\"",
    "electron:build": "npm run electron:compile && npm run build"
  },
  "dependencies": {
    "exceljs": "^4.4.0",
    "lucide-react": "^0.468.0",
    "papaparse": "^5.5.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "sql.js": "^1.14.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.8",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.7.4",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/sql.js": "^1.4.11",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.0.1",
    "electron": "^31.0.0",
    "jsdom": "^24.1.1",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.5.4",
    "vite": "^5.4.10",
    "vitest": "^2.1.1",
    "wait-on": "^8.0.1"
  }
}
